---
interface Props {
  href?: string;
  text: string;
  class?: string;
}

const { href, text, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class={`inline-flex items-center justify-center px-8 py-3 bg-igt-cyan text-black font-semibold rounded-lg hover:bg-igt-cyan-dark transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-igt-cyan/50 ${className}`}
  style="color:#000"
>
  {text}
</Tag>
