---
interface Props {
  name: string;
  role: string;
  bio: string;
  image: string;
  imagePosition?: string;
  class?: string;
}

const { name, role, bio, image, imagePosition = 'center', class: className = '' } = Astro.props;
---

<div class={`bg-slate-900 border border-slate-800 rounded-lg overflow-hidden hover:border-igt-cyan transition-all duration-300 ${className}`}>
  <div class="aspect-square overflow-hidden bg-slate-950">
    <img 
      src={image} 
      alt={name}
      class="w-full h-full object-cover"
      style={`object-position: ${imagePosition}`}
      loading="lazy"
      width="400"
      height="400"
    />
  </div>
  <div class="p-6">
    <h3 class="text-xl font-semibold text-white mb-1">{name}</h3>
    <p class="text-igt-cyan text-sm font-medium mb-3">{role}</p>
    <p class="text-slate-400 text-sm">{bio}</p>
  </div>
</div>
