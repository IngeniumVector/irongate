---
interface Props {
  icon: string; // emoji or icon
  title: string;
  description: string;
  class?: string;
}

const { icon, title, description, class: className = '' } = Astro.props;
---

<div class={`bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-igt-cyan transition-all duration-300 ${className}`}>
  <div class="text-4xl mb-4 anim-float" set:html={icon} aria-hidden="true"></div>
  <h3 class="text-lg font-semibold text-white mb-2">{title}</h3>
  <p class="text-slate-400 text-sm">{description}</p>
</div>
