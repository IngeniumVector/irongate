---
// LogoGrid.astro - Client/partner logo social proof section
// Placement: Homepage, just above Final CTA section
// Logo files go in /images/logos/ directory

const logos = [
  { name: "Ashley Condominiums", file: "ashley-condominiums.webp", alt: "The Ashley Condominium logo", width: 280, height: 221, url: "https://www.ashleycondo.com/" },
  { name: "f3 Marinas", file: "f3-marinas.webp", alt: "F3 Marinas logo", width: 314, height: 282, url: "https://f3marina.com/" },
  // Add more logos here as they become available:
  // { name: "Client Name", file: "client-name.webp", alt: "Client Name logo", width: 0, height: 0, url: "https://example.com/" },
];
---

<section class="bg-slate-950 border-y border-slate-800 py-12">
  <div class="container mx-auto px-4 md:px-6 max-w-7xl">
    <p class="text-center text-sm font-medium text-slate-400 uppercase tracking-widest mb-8">Organizations We Protect</p>
    <div class="flex flex-wrap items-center justify-center gap-12 md:gap-16">
      {logos.map((logo) => (
        <div class="flex flex-col items-center gap-3 grayscale hover:grayscale-0 transition-all duration-300 opacity-60 hover:opacity-100">
          <div class="flex items-center justify-center px-4" style="height:56px;">
            <img src={`/images/logos/${logo.file}`} alt={logo.alt} style="height:40px;width:auto;max-width:140px;object-fit:contain;" width={logo.width} height={logo.height} loading="lazy" />
          </div>
          <a href={logo.url} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-400 hover:text-cyan-400 transition-colors">{logo.url.replace('https://', '').replace('www.', '').replace(/\/$/, '')}</a>
        </div>
      ))}
    </div>
  </div>
</section>
