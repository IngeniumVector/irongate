---
interface Props {
  variant?: 'homepage' | 'homepage-bg' | 'product' | 'centered' | 'split';
  title: string;
  subtitle?: string;
  badge?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  class?: string;
}

const { 
  variant = 'centered', 
  title, 
  subtitle, 
  badge,
  description,
  image,
  imageAlt,
  class: className = '' 
} = Astro.props;
---

{variant === 'homepage-bg' && (
  <section class={`relative min-h-screen flex items-center ${className}`}>
    {/* Background Image */}
    {image && (
      <div class="absolute inset-0">
        <img src={image} alt={imageAlt || ''} class="w-full h-full object-cover anim-ken-burns" width="1080" height="1440" />
        <div class="absolute inset-0 bg-black/60"></div>
      </div>
    )}
    
    {/* Content */}
    <div class="container mx-auto px-4 md:px-6 max-w-7xl relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        {badge && (
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-900/80 border border-slate-700 rounded-full mb-6">
            <span class="w-2 h-2 bg-igt-cyan rounded-full animate-pulse"></span>
            <span class="text-sm text-slate-300">{badge}</span>
          </div>
        )}
        {subtitle && <p class="text-igt-cyan font-semibold mb-4 tracking-wide text-lg italic" style="text-shadow: 0 2px 8px rgba(0,0,0,0.7);" set:html={subtitle} />}
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8);">
          {title}
        </h1>
        {description && <p class="text-lg md:text-xl text-slate-300 mb-8" style="text-shadow: 0 1px 6px rgba(0,0,0,0.6);">{description}</p>}
        <slot name="cta" />
      </div>
    </div>
  </section>
)}

{variant === 'homepage' && (
  <section class={`relative min-h-screen flex items-center bg-gradient-to-br from-black via-slate-950 to-slate-900 ${className}`}>
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-5"></div>
    <div class="container mx-auto px-4 md:px-6 max-w-7xl relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          {subtitle && <p class="text-igt-cyan font-semibold mb-4 tracking-wide uppercase text-sm">{subtitle}</p>}
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
            {title}
          </h1>
          {description && <p class="text-lg md:text-xl text-slate-400 mb-8">{description}</p>}
          <slot name="cta" />
        </div>
        {image && (
          <div class="relative">
            <img src={image} alt={imageAlt || ''} class="w-full rounded-lg shadow-2xl shadow-igt-cyan/20" width="1080" height="1440" loading="lazy" />
          </div>
        )}
      </div>
    </div>
  </section>
)}

{variant === 'product' && (
  <section class={`bg-gradient-to-br from-slate-950 to-slate-900 py-24 ${className}`}>
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <div class="max-w-4xl">
        {subtitle && <p class="text-igt-cyan font-semibold mb-4 tracking-wide uppercase text-sm">{subtitle}</p>}
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
          {title}
        </h1>
        {description && <p class="text-xl text-slate-400 mb-8">{description}</p>}
        <slot name="cta" />
      </div>
    </div>
  </section>
)}

{variant === 'centered' && (
  <section class={`bg-gradient-to-br from-slate-950 to-slate-900 py-24 text-center ${className}`}>
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <div class="max-w-3xl mx-auto">
        {subtitle && <p class="text-igt-cyan font-semibold mb-4 tracking-wide uppercase text-sm">{subtitle}</p>}
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
          {title}
        </h1>
        {description && <p class="text-xl text-slate-400 mb-8">{description}</p>}
        <slot name="cta" />
      </div>
    </div>
  </section>
)}

{variant === 'split' && (
  <section class={`bg-gradient-to-br from-black via-slate-950 to-slate-900 ${className}`}>
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[600px]">
        <div>
          {subtitle && <p class="text-igt-cyan font-semibold mb-4 tracking-wide uppercase text-sm">{subtitle}</p>}
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
            {title}
          </h1>
          {description && <p class="text-lg text-slate-400 mb-8">{description}</p>}
          <slot name="cta" />
        </div>
        {image && (
          <div class="relative">
            <img src={image} alt={imageAlt || ''} class="w-full rounded-lg" width="1080" height="1440" loading="lazy" />
          </div>
        )}
      </div>
    </div>
  </section>
)}
