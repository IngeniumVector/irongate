---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Solutions', href: '/solutions' },
  { label: 'Industries', href: '/industries/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Team', href: '/team' },
  { label: 'Contact', href: '/contact' },
];

const industryLinks = [
  { label: 'Construction', href: '/solutions/construction/' },
  { label: 'Marine', href: '/solutions/marine/' },
  { label: 'Houses of Worship', href: '/solutions/churches/' },
  { label: 'Schools', href: '/solutions/schools/' },
  { label: 'Healthcare', href: '/solutions/healthcare/' },
  { label: 'Government', href: '/solutions/government/' },
  { label: 'Logistics', href: '/solutions/logistics/' },
  { label: 'Commercial', href: '/solutions/commercial/' },
  { label: 'Industrial', href: '/solutions/industrial/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
];
---

<footer class="bg-slate-950 border-t border-slate-800 py-8" aria-label="Site footer">
  <div class="container mx-auto px-4 md:px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-6">
      <!-- Logo & Motto -->
      <div>
        <img src="/logo.webp" alt="Iron Gate Technologies shield logo" class="h-10 mb-2 anim-pulse-glow" width="616" height="442" style="aspect-ratio:616/442;width:auto" />
        <p class="text-slate-400 italic mb-2 cursor-default select-text">"In God We Trust. All Others We Track.™"</p>
        <p class="text-slate-400 text-sm">
          American-made security solutions for a safer tomorrow.
        </p>
        <a href="https://www.linkedin.com/company/es-iron-gate-technologies-llc" target="_blank" rel="noopener noreferrer" class="inline-block text-slate-400 hover:text-igt-cyan transition-colors mt-4" aria-label="Iron Gate Technologies on LinkedIn">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- Quick Links -->
      <nav aria-label="Quick links">
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-slate-400 hover:text-igt-cyan transition-colors py-1 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Industries -->
      <nav aria-label="Industries">
        <h3 class="text-white font-semibold mb-4">Industries</h3>
        <ul class="space-y-2">
          {industryLinks.map(link => (
            <li>
              <a href={link.href} class="text-slate-400 hover:text-igt-cyan transition-colors py-1 inline-block text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-2 text-slate-400 text-sm">
          <li>
            <a href="tel:+19048965618" class="hover:text-igt-cyan transition-colors py-1 inline-block">
              904-896-5618
            </a>
          </li>
          <li>
            <a href="mailto:ats@irongate.world" class="hover:text-igt-cyan transition-colors py-1 inline-block">
              ats@irongate.world
            </a>
          </li>
          <li class="pt-2">
            <a href="https://maps.google.com/?q=232+Carswell+Ave+Holly+Hill+FL+32117" target="_blank" rel="noopener noreferrer" class="hover:text-igt-cyan transition-colors">
              232 Carswell Ave<br />
              Holly Hill, FL 32117
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-400 text-sm">
        © {currentYear} ES Iron Gate Technologies LLC. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        {legalLinks.map(link => (
          <a href={link.href} class="text-slate-400 text-sm hover:text-igt-cyan transition-colors py-1 inline-block">
            {link.label}
          </a>
        ))}
        <span class="text-slate-400 text-xs" aria-hidden="true">|</span>
        <span class="text-slate-400 text-xs">Made by <a href="https://ingeniumvector.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-cyan-400 transition-colors">IngeniumVector.com</a></span>
      </div>
    </div>
  </div>
</footer>
