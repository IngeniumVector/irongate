---
interface Props {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'url';
  placeholder?: string;
  required?: boolean;
  class?: string;
}

const { name, label, type = 'text', placeholder, required = false, class: className = '' } = Astro.props;
---

<div class={`mb-4 ${className}`}>
  <label for={name} class="block text-sm font-medium text-slate-300 mb-2">
    {label}
    {required && <span class="text-igt-cyan">*</span>}
  </label>
  <input
    type={type}
    id={name}
    name={name}
    placeholder={placeholder}
    required={required}
    class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:border-igt-cyan focus:outline-none focus:ring-1 focus:ring-igt-cyan transition-colors"
  />
</div>
