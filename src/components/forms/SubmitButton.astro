---
interface Props {
  text?: string;
  class?: string;
}

const { text = 'Submit', class: className = '' } = Astro.props;
---

<button
  type="submit"
  class={`w-full px-8 py-3 bg-igt-cyan text-black font-semibold rounded-lg hover:bg-igt-cyan-dark transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-igt-cyan/50 ${className}`}
>
  {text}
</button>
