---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
import FeatureCard from '../../components/cards/FeatureCard.astro';
import ButtonPrimary from '../../components/buttons/ButtonPrimary.astro';
---

<BaseLayout 
  title="RaptorNet Industrial WiFi and Connectivity" 
  description="Industrial-grade WiFi and broadband supporting security systems. Weather-resistant, scalable networking for facilities that demand reliability."
>
  <script type="application/ld+json" is:inline>

{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "https://irongate.world/solutions/network-infrastructure/#product",
  "name": "Iron Gate Technologies RaptorNet",
  "description": "Industrial-grade WiFi and broadband infrastructure built for security deployments in demanding environments. Weather-resistant access points covering up to 1,200 feet.",
  "brand": {
    "@id": "https://irongate.world/#organization"
  },
  "manufacturer": {
    "@id": "https://irongate.world/#organization"
  },
  "category": "Industrial Network Infrastructure",
  "image": "https://irongate.world/images/products/mifi-antenna-with-secmod.webp",
  "url": "https://irongate.world/solutions/network-infrastructure/",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Grade",
      "value": "Industrial-grade"
    },
    {
      "@type": "PropertyValue",
      "name": "Durability",
      "value": "Weather-resistant"
    },
    {
      "@type": "PropertyValue",
      "name": "Range",
      "value": "Up to 1,200 feet"
    },
    {
      "@type": "PropertyValue",
      "name": "Scalability",
      "value": "Scalable for any facility size"
    },
    {
      "@type": "PropertyValue",
      "name": "Manufacturing",
      "value": "Made in USA (Holly Hill, FL)"
    }
  ],
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "USD",
      "valueAddedTaxIncluded": false
    },
    "warranty": {
      "@type": "WarrantyPromise",
      "durationOfWarranty": {
        "@type": "QuantitativeValue",
        "value": 3,
        "unitCode": "ANN"
      },
      "warrantyScope": "Network Infrastructure"
    },
    "seller": {
      "@id": "https://irongate.world/#organization"
    }
  }
}

  </script>
    <!-- FAQPage Schema (GEO) -->
    <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the WiFi range of RaptorNet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "RaptorNet access points provide coverage up to 1,200 feet. The weather-resistant units are designed for outdoor deployment at construction sites, industrial facilities, and large campuses."
      }
    },
    {
      "@type": "Question",
      "name": "Is RaptorNet only for Iron Gate security products?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. While RaptorNet is optimized to support Iron Gate surveillance and access control systems, it provides standard WiFi 6 connectivity for any network-connected devices at your facility."
      }
    },
    {
      "@type": "Question",
      "name": "Can RaptorNet handle extreme weather?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. RaptorNet access points are built with weather-resistant housing rated for extreme conditions including heat, humidity, rain, and high winds. They are designed for permanent outdoor installation."
      }
    },
    {
      "@type": "Question",
      "name": "Does RaptorNet require existing network infrastructure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "RaptorNet can work with existing infrastructure or serve as a standalone network. For remote sites with no existing connectivity, it pairs with cellular backhaul to provide WiFi coverage where none existed before."
      }
    },
    {
      "@type": "Question",
      "name": "How is the RaptorNet network segmented to isolate security devices from corporate IT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "RaptorNet supports VLAN configuration to isolate surveillance cameras, access control hubs, and other security hardware from your primary corporate network. This segmentation prevents lateral movement if any exterior device is physically compromised, following industry-standard defense-in-depth practices."
      }
    }
  ]
}
    </script>

  <!-- Hero with Background Image -->
  <section class="relative min-h-[60vh] flex items-center">
    <div class="absolute inset-0">
      <img
        src="/images/products/mifi-antenna-with-secmod.webp"
        srcset="/images/products/mifi-antenna-with-secmod-640w.webp 640w, /images/products/mifi-antenna-with-secmod.webp 1400w"
        sizes="100vw"
        alt="MiFi antenna deployed alongside a SecMods unit for integrated connectivity"
        width="1400"
        height="1050"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="container mx-auto px-4 md:px-6 max-w-7xl relative z-10 py-24">
      <div class="max-w-3xl bg-black/75 backdrop-blur-sm rounded-2xl p-8 md:p-12">
        <p class="text-igt-cyan font-semibold mb-4 tracking-wide uppercase text-sm">Connectivity Solutions</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">RaptorNet</h1>
        <p class="text-xl text-slate-300 mb-8 max-w-2xl">Industrial-grade WiFi and broadband infrastructure that supports your security systems. Weather-resistant, scalable, and built for reliability in demanding environments.</p>
      </div>
    </div>
  </section>

  <!-- Answer-First Paragraph (GEO) -->
  <section class="bg-slate-950 pt-12 pb-0">
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <p class="text-lg text-slate-300 max-w-3xl mx-auto text-center mb-12">Iron Gate RaptorNet is industrial-grade WiFi and broadband infrastructure built for security deployments in demanding environments. Weather-resistant access points cover up to 1,200 feet, providing the connectivity backbone for cameras, access control, and monitoring systems.</p>
    </div>
  </section>

  <!-- Challenge / Solution -->
  <Section class="bg-slate-950">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title="The Challenge" subtitle="Consumer networks fail under security demands" />
      <p class="text-slate-400 text-lg text-center mb-12">
Security systems require 24/7 connectivity with consistent performance. Consumer-grade routers and access points fail in warehouses, outdoor yards, and industrial environments. High-resolution cameras saturate network bandwidth. When the internet goes down, security goes blind. And troubleshooting network issues becomes a nightmare without proper monitoring tools.
</p>
      <SectionHeader title="The Solution" subtitle="Infrastructure built for security" />
      <p class="text-slate-400 text-lg text-center">
Iron Gate designs and deploys industrial-grade networks specifically for security system requirements. Weather-resistant access points provide outdoor coverage. Managed switches with PoE eliminate separate power runs to cameras. Cellular failover maintains connectivity during internet outages. Network monitoring alerts you to problems before systems go offline. The result is reliable, scalable infrastructure that grows with your security needs.
</p>
    </div>
  </Section>

  <!-- Capabilities -->
  <Section>
    <SectionHeader title="Capabilities" subtitle="Enterprise infrastructure, simplified" />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <FeatureCard icon='<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>' title="Industrial WiFi" description="Enterprise-grade wireless coverage for harsh environments. Weather-resistant access points rated for extreme temperatures. Maintain connectivity in warehouses, yards, and construction sites." />
      <FeatureCard icon='<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' title="Secure by Design" description="WPA3 encryption and network segmentation. Isolated VLANs for security systems and business operations. Intrusion detection and prevention systems monitor all traffic." />
      <FeatureCard icon='<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' title="Cellular Failover" description="Automatic switchover to cellular backup when primary internet fails. Maintain security system connectivity even during outages. Multi-carrier support for redundancy." />
      <FeatureCard icon='<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>' title="Power over Ethernet" description="PoE+ switches power cameras, access points, and other devices over network cables. Reduce installation costs by eliminating separate power runs. Centralized power management and backup." />
      <FeatureCard icon='<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>' title="Network Monitoring" description="Real-time visibility into network health and performance. Automatic alerts for connectivity issues or performance degradation. Historical analytics for capacity planning." />
      <FeatureCard icon='<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>' title="Professional Installation" description="Site survey and network design by certified engineers. Structured cabling with proper documentation. Performance testing and optimization before handoff." />
    </div>
  </Section>


  <!-- Mid-Page CTA -->
  <div class="text-center py-12 bg-slate-950/50 border-y border-slate-800">
    <p class="text-slate-400 mb-4">Ready to see how Iron Gate can protect your operation?</p>
    <ButtonPrimary href="/booking" text="Book a Security Assessment" />
  </div>

  <!-- Technical Specifications -->
  <Section class="bg-slate-950">
    <SectionHeader title="Technical Specifications" subtitle="Industrial-grade performance" />
    <div class="max-w-3xl mx-auto">
      <div class="bg-slate-900/50 rounded-lg overflow-hidden border border-slate-800">
        <div class="divide-y divide-slate-800">
          <div class="spec-row">
            <span class="text-slate-400">WiFi Standard</span>
            <span class="text-white font-medium">WiFi 6 (802.11ax)</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Coverage per AP</span>
            <span class="text-white font-medium">Up to 5,000 sq ft (Indoor)</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Outdoor Range</span>
            <span class="text-white font-medium">Up to 1,200 feet (Line of Sight)</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Concurrent Devices</span>
            <span class="text-white font-medium">200+ per Access Point</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Switch Capacity</span>
            <span class="text-white font-medium">Up to 48 Ports per Switch</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">PoE Budget</span>
            <span class="text-white font-medium">Up to 740W per Switch</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Operating Temp</span>
            <span class="text-white font-medium">-40°F to 149°F (Outdoor)</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Failover Time</span>
            <span class="text-white font-medium">&lt;30 Seconds to Cellular</span>
          </div>
        </div>
      </div>
      <p class="text-slate-400 text-sm text-center mt-6">
Network design customized for your facility layout and device count. Contact us for a site survey and proposal.
</p>
    </div>
  </Section>

  <!-- Applications -->
  <Section>
    <SectionHeader title="Applications" subtitle="Where reliable networks matter most" />
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800 hover:border-igt-cyan transition-colors">
        <h3 class="text-xl font-semibold text-white mb-3">Large Facilities</h3>
        <p class="text-slate-400">Warehouses, manufacturing plants, and distribution centers need WiFi coverage across hundreds of thousands of square feet. Our mesh networks scale cost-effectively while maintaining performance.</p>
      </div>
      <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800 hover:border-igt-cyan transition-colors">
        <h3 class="text-xl font-semibold text-white mb-3">Outdoor Coverage</h3>
        <p class="text-slate-400">Yards, parking lots, and loading docks require weather-resistant access points. Our industrial-grade equipment operates in extreme conditions while supporting security cameras and mobile devices.</p>
      </div>
      <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800 hover:border-igt-cyan transition-colors">
        <h3 class="text-xl font-semibold text-white mb-3">Multi-Site Deployments</h3>
        <p class="text-slate-400">Enterprises with multiple locations need consistent network architecture. Centralized management simplifies administration. Cloud-based controllers enable remote monitoring and configuration.</p>
      </div>
    </div>
  </Section>

  <!-- Complete Security Ecosystem -->
  <Section class="bg-slate-950">
    <SectionHeader title="Complete Security Ecosystem" subtitle="Networks designed for Iron Gate systems" />
    <div class="max-w-4xl mx-auto">
      <div class="max-w-md mx-auto mb-10">
        <img
          src="/images/products/mifi-antenna-closeup.webp"
          srcset="/images/products/mifi-antenna-closeup-640w.webp 640w, /images/products/mifi-antenna-closeup.webp 1400w"
          sizes="(max-width: 768px) 100vw, 448px"
          alt="Industrial MiFi antenna closeup showing weather-resistant construction"
          width="1400"
          height="1050"
          loading="lazy"
          class="rounded-lg border border-slate-800"
        />
        <p class="text-slate-400 text-sm text-center mt-3">Weather-resistant antenna hardware built for continuous outdoor operation.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800">
          <h4 class="text-lg font-semibold text-white mb-2">4K Camera Support</h4>
          <p class="text-slate-400 text-sm">
Bandwidth and QoS prioritization for high-resolution video streams without dropouts or buffering.
</p>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800">
          <h4 class="text-lg font-semibold text-white mb-2">Access Control Integration</h4>
          <p class="text-slate-400 text-sm">
Low-latency connectivity for door controllers and card readers with under 50ms response times.
</p>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800">
          <h4 class="text-lg font-semibold text-white mb-2">Robot Connectivity</h4>
          <p class="text-slate-400 text-sm">
Mesh networking supports autonomous patrol robots with seamless roaming across facilities.
</p>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800">
          <h4 class="text-lg font-semibold text-white mb-2">Cloud Services</h4>
          <p class="text-slate-400 text-sm">
Adequate upstream bandwidth for cloud recording and remote system access.
</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Warranty -->
  <div class="max-w-3xl mx-auto mt-8">
    <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-4 flex items-center justify-center gap-4">
      <div class="text-2xl font-bold text-igt-cyan">3-Year Warranty</div>
      <div class="text-slate-400 text-sm">on all network infrastructure components</div>
    </div>
    <p class="text-slate-400 text-sm text-center mt-4">If something does go wrong, our overnight RMA program ships a replacement unit the next business day. Every Iron Gate customer has access to our 24/7 dedicated support line. No call centers, no ticket queues.</p>
  </div>


  <!-- FAQ Section (GEO) -->
  <Section class="bg-slate-950">
    <SectionHeader title="Frequently Asked Questions" />
    <div class="max-w-3xl mx-auto space-y-4">
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        What is the WiFi range of RaptorNet?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">RaptorNet access points provide coverage up to 1,200 feet. The weather-resistant units are designed for outdoor deployment at construction sites, industrial facilities, and large campuses.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        Is RaptorNet only for Iron Gate security products?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">No. While RaptorNet is optimized to support Iron Gate surveillance and access control systems, it provides standard WiFi 6 connectivity for any network-connected devices at your facility.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        Can RaptorNet handle extreme weather?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">Yes. RaptorNet access points are built with weather-resistant housing rated for extreme conditions including heat, humidity, rain, and high winds. They are designed for permanent outdoor installation.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        Does RaptorNet require existing network infrastructure?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">RaptorNet can work with existing infrastructure or serve as a standalone network. For remote sites with no existing connectivity, it pairs with cellular backhaul to provide WiFi coverage where none existed before.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        How is the RaptorNet network segmented to isolate security devices from corporate IT?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">RaptorNet supports VLAN configuration to isolate surveillance cameras, access control hubs, and other security hardware from your primary corporate network. This segmentation prevents lateral movement if any exterior device is physically compromised, following industry-standard defense-in-depth practices.</p>
    </details>
    </div>
  </Section>
  <!-- CTA -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-slate-950 to-black">
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
Build a Network Your Security Can Rely On
</h2>
        <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
Free site survey and network design proposal. We'll assess your facility and recommend the right infrastructure for your security systems.
</p>
        <ButtonPrimary href="/booking" text="Book a Security Assessment" />
      </div>
    </div>
  </section>

</BaseLayout>
