---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
import FeatureCard from '../../components/cards/FeatureCard.astro';
import ButtonPrimary from '../../components/buttons/ButtonPrimary.astro';
---

<BaseLayout 
  title="Autonomous Patrol Robots" 
  description="Self-navigating patrol units with AI-powered threat detection. Stair-climbing robots that provide 24/7 security coverage for large facilities."
>
  <script type="application/ld+json" is:inline>

{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "https://irongate.world/solutions/autonomous-robots/#product",
  "name": "ES Iron Gate Technologies Autonomous Patrol Robot",
  "description": "Self-navigating security unit providing 24/7 mobile surveillance. Climbs stairs, identifies weapons using AI-powered threat detection, and operates autonomously on solar power.",
  "brand": {
    "@id": "https://irongate.world/#organization"
  },
  "manufacturer": {
    "@id": "https://irongate.world/#organization"
  },
  "category": "Autonomous Security Robots",
  "image": [
    "https://irongate.world/images/products/Robot_1.webp",
    "https://irongate.world/images/products/Robot_2.webp"
  ],
  "url": "https://irongate.world/solutions/autonomous-robots/",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Navigation",
      "value": "Self-navigating, stair-climbing"
    },
    {
      "@type": "PropertyValue",
      "name": "AI Capability",
      "value": "Weapon identification"
    },
    {
      "@type": "PropertyValue",
      "name": "Operation",
      "value": "24/7 autonomous, solar-powered"
    },
    {
      "@type": "PropertyValue",
      "name": "Manufacturing",
      "value": "Made in USA (Holly Hill, FL)"
    }
  ],
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "USD",
      "valueAddedTaxIncluded": false
    },
    "warranty": {
      "@type": "WarrantyPromise",
      "durationOfWarranty": {
        "@type": "QuantitativeValue",
        "value": 3,
        "unitCode": "ANN"
      },
      "warrantyScope": "Autonomous Patrol Robots"
    },
    "seller": {
      "@id": "https://irongate.world/#organization"
    }
  }
}

  </script>
    <!-- FAQPage Schema (GEO) -->
    <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can the patrol robots climb stairs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Iron Gate's Autonomous Patrol Robots are built with stair-climbing capability, allowing them to patrol multi-level facilities including parking garages, stairwells, and tiered outdoor environments."
      }
    },
    {
      "@type": "Question",
      "name": "How do the robots detect threats?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The robots use AI-powered computer vision for weapon identification and threat detection. They analyze their surroundings continuously and send real-time alerts when potential threats are identified. All AI systems comply with ISO/IEC 42001."
      }
    },
    {
      "@type": "Question",
      "name": "Do the robots need human operators?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. The robots operate autonomously, following programmed patrol routes and making real-time navigation decisions. They recharge via solar power and can run 24/7 without human intervention. Human operators can override and direct the robots remotely when needed."
      }
    },
    {
      "@type": "Question",
      "name": "What environments are the patrol robots designed for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The robots are designed for warehouses, office campuses, parking structures, industrial facilities, and any environment that needs continuous mobile surveillance. They operate in both indoor and outdoor settings."
      }
    }
  ]
}
    </script>

  <!-- Hero with Background Image -->
  <section class="relative min-h-[60vh] flex items-center">
    <div class="absolute inset-0">
      <img
        src="/images/products/Robot_1.webp"
        srcset="/images/products/Robot_1-640w.webp 640w, /images/products/Robot_1-1024w.webp 1024w, /images/products/Robot_1.webp 1400w"
        sizes="100vw"
        alt="Iron Gate autonomous patrol robot"
        width="1400"
        height="1050"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="container mx-auto px-4 md:px-6 max-w-7xl relative z-10 py-24">
      <div class="max-w-3xl bg-black/75 backdrop-blur-sm rounded-2xl p-8 md:p-12">
        <p class="text-igt-cyan font-semibold mb-4 tracking-wide uppercase text-sm">Mobile Security</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">Autonomous Patrol Robots</h1>
        <p class="text-xl text-slate-300 mb-8 max-w-2xl">Self-navigating patrol units that provide 24/7 security coverage. Stair-climbing capability, AI-powered threat detection, and autonomous operation for facilities that never sleep.</p>
      </div>
    </div>
  </section>

  <!-- Answer-First Paragraph (GEO) -->
  <section class="bg-slate-950 pt-12 pb-0">
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <p class="text-lg text-slate-300 max-w-3xl mx-auto text-center mb-12">The Iron Gate Autonomous Patrol Robot is a self-navigating security unit providing 24/7 mobile surveillance. It climbs stairs, identifies weapons using AI-powered threat detection, and operates autonomously on solar power. Built for facilities needing continuous perimeter coverage without staffing constraints.</p>
    </div>
  </section>

  <!-- Video Demo -->
  <Section>
    <SectionHeader title="See It In Action" subtitle="Watch the autonomous patrol robot navigate and patrol" />
    <div class="max-w-4xl mx-auto">
      <video 
        class="w-full rounded-lg shadow-lg border border-slate-800" 
        controls 
        muted 
        playsinline 
        preload="metadata"
        poster="/images/products/autonomous-robot-poster.webp"
      >
        <source src="/videos/autonomous-robot-demo.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
      <p class="text-slate-400 text-sm text-center mt-4">Autonomous patrol robot demonstrating navigation and surveillance capabilities.</p>
    </div>
  </Section>

  <!-- Challenge / Solution -->
  <Section class="bg-slate-950">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title="The Challenge" subtitle="Static cameras miss mobile threats" />
      <p class="text-slate-400 text-lg text-center mb-12">
Fixed cameras create blind spots. Human guards fatigue after hours of repetitive patrols. Large facilities require multiple guards to cover adequately, driving costs skyward. Consistent patrol quality is nearly impossible when human attention wanes. And guards themselves face danger in high-risk environments or late-night patrols.
</p>
      <SectionHeader title="The Solution" subtitle="Mobile security that never tires" />
      <p class="text-slate-400 text-lg text-center">
Autonomous patrol robots eliminate these limitations. They execute identical patrols hour after hour with perfect consistency. AI-powered threat detection never gets bored or distracted. Stair-climbing capability provides access to multi-level facilities. Real-time alerts notify human security when intervention is needed. The result is superior coverage at a fraction of the cost of manned patrols.
</p>
    </div>
  </Section>

  <!-- Capabilities -->
  <Section>
    <SectionHeader title="Capabilities" subtitle="Intelligence that moves" />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <FeatureCard icon="<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>" title="Autonomous Navigation" description="Self-navigating patrol units that learn facility layouts. Automatic path planning and obstacle avoidance. No human operator required for routine patrols." />
      <FeatureCard icon="<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v18M16 3v18M8 7h8M8 11h8M8 15h8M8 19h8"/></svg>" title="Stair Climbing" description="Navigate multi-level facilities without elevators. Tank-style treads or specialized mechanisms for stairs and ramps. Access areas human guards find difficult or dangerous." />
      <FeatureCard icon="<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>" title="Weapon Detection" description="AI-powered computer vision identifies firearms and other weapons. Instant alerts with photo evidence. Threat assessment and automatic response protocols. All AI detection systems are developed in compliance with ISO/IEC 42001, the international standard for AI management systems." />
      <FeatureCard icon="<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>" title="Extended WiFi Coverage" description="Each unit extends network coverage up to 16 acres. Mobile mesh networking for large facilities. Maintain connectivity in previously dead zones." />
      <FeatureCard icon="<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/></svg>" title="Environmental Sensors" description="Detect smoke, gas leaks, and temperature anomalies. Early warning system for fires and hazardous conditions. Integration with building management systems." />
      <FeatureCard icon="<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>" title="Two-Way Audio" description="Remote communication through onboard speakers and microphones. Security personnel can address trespassers. Verbal warnings before escalating response." />
    </div>
  </Section>


  <!-- Mid-Page CTA -->
  <div class="text-center py-12 bg-slate-950/50 border-y border-slate-800">
    <p class="text-slate-400 mb-4">Ready to see how Iron Gate can protect your operation?</p>
    <ButtonPrimary href="/booking" text="Book a Security Assessment" />
  </div>

  <!-- Technical Specifications -->
  <Section class="bg-slate-950">
    <SectionHeader title="Technical Specifications" subtitle="Built for demanding environments" />
    <div class="max-w-3xl mx-auto">
      <div class="bg-slate-900/50 rounded-lg overflow-hidden border border-slate-800">
        <div class="divide-y divide-slate-800">
          <div class="spec-row">
            <span class="text-slate-400">Patrol Speed</span>
            <span class="text-white font-medium">Up to 3 MPH</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Battery Life</span>
            <span class="text-white font-medium">8-12 Hours Continuous</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Charging Time</span>
            <span class="text-white font-medium">Auto-Docking in 4 Hours</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Camera System</span>
            <span class="text-white font-medium">360 4K with Night Vision</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">WiFi Range</span>
            <span class="text-white font-medium">Up to 16 Acres Coverage</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Terrain</span>
            <span class="text-white font-medium">Indoor/Outdoor, Stairs, Ramps</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Weather Rating</span>
            <span class="text-white font-medium">IP65 Dust/Water Resistant</span>
          </div>
          <div class="spec-row">
            <span class="text-slate-400">Weight</span>
            <span class="text-white font-medium">120-180 lbs (Model Dependent)</span>
          </div>
        </div>
      </div>
      <p class="text-slate-400 text-sm text-center mt-6">
Specifications vary by model and configuration. Contact us for detailed specs matching your facility.
</p>
    </div>
  </Section>

  <!-- Robot Models -->
  <Section>
    <SectionHeader title="Built for Any Facility" subtitle="Iron Gate patrol robots in the field" />
    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <img
        src="/images/products/Robot_1.webp"
        srcset="/images/products/Robot_1-640w.webp 640w, /images/products/Robot_1-1024w.webp 1024w, /images/products/Robot_1.webp 1400w"
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Iron Gate autonomous patrol robot, front view"
        width="1400"
        height="1050"
        loading="lazy"
        class="rounded-lg border border-slate-800"
      />
      <img
        src="/images/products/Robot_2.webp"
        alt="Iron Gate autonomous patrol robot, alternate configuration"
        width="1400"
        height="1050"
        loading="lazy"
        class="rounded-lg border border-slate-800"
      />
    </div>
  </Section>

  <!-- Applications with AI Navigation Visual -->
  <Section>
    <SectionHeader title="Applications" subtitle="Where robots excel" />
    <div class="max-w-2xl mx-auto mb-10">
      <img
        src="/images/products/robot-ai-navigation.webp"
        srcset="/images/products/robot-ai-navigation-640w.webp 640w, /images/products/robot-ai-navigation.webp 1400w"
        sizes="(max-width: 768px) 100vw, 672px"
        alt="AI navigation system visualization showing autonomous path planning"
        width="1400"
        height="1050"
        loading="lazy"
        class="rounded-lg border border-slate-800"
      />
      <p class="text-slate-400 text-sm text-center mt-3">AI-powered navigation maps the environment in real-time, identifying optimal patrol routes and detecting obstacles.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800 hover:border-igt-cyan transition-colors">
        <h3 class="text-xl font-semibold text-white mb-3">Corporate Campuses</h3>
        <p class="text-slate-400">Patrol large facilities 24/7 without fatigue. Multiple robots cover more ground than human guards at lower cost. Consistent, repeatable security checks with documented proof.</p>
      </div>
      <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800 hover:border-igt-cyan transition-colors">
        <h3 class="text-xl font-semibold text-white mb-3">Warehouses &amp; Distribution</h3>
        <p class="text-slate-400">Monitor vast warehouse floors and outdoor yards. Detect unauthorized access after hours. Verify facility security before staff arrival. Reduce liability with proactive threat detection.</p>
      </div>
      <div class="bg-slate-900/50 rounded-lg p-6 border border-slate-800 hover:border-igt-cyan transition-colors">
        <h3 class="text-xl font-semibold text-white mb-3">Educational Institutions</h3>
        <p class="text-slate-400">Campus security that never sleeps. Patrol parking lots, buildings, and grounds. Weapon detection for active threat response. Supplement human security staff cost-effectively.</p>
      </div>
    </div>
  </Section>

  <!-- Warranty -->
  <div class="max-w-3xl mx-auto mt-8">
    <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-4 flex items-center justify-center gap-4">
      <div class="text-2xl font-bold text-igt-cyan">3-Year Warranty</div>
      <div class="text-slate-400 text-sm">on all robot system components</div>
    </div>
    <p class="text-slate-400 text-sm text-center mt-4">If something does go wrong, our overnight RMA program ships a replacement unit the next business day. Every Iron Gate customer has access to our 24/7 dedicated support line. No call centers, no ticket queues.</p>
  </div>


  <!-- FAQ Section (GEO) -->
  <Section class="bg-slate-950">
    <SectionHeader title="Frequently Asked Questions" />
    <div class="max-w-3xl mx-auto space-y-4">
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        Can the patrol robots climb stairs?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">Yes. Iron Gate's Autonomous Patrol Robots are built with stair-climbing capability, allowing them to patrol multi-level facilities including parking garages, stairwells, and tiered outdoor environments.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        How do the robots detect threats?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">The robots use AI-powered computer vision for weapon identification and threat detection. They analyze their surroundings continuously and send real-time alerts when potential threats are identified. All AI systems comply with ISO/IEC 42001.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        Do the robots need human operators?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">No. The robots operate autonomously, following programmed patrol routes and making real-time navigation decisions. They recharge via solar power and can run 24/7 without human intervention. Human operators can override and direct the robots remotely when needed.</p>
    </details>
    <details class="bg-slate-900 border border-slate-800 rounded-lg p-6 group">
      <summary class="cursor-pointer font-semibold text-white flex justify-between items-center">
        What environments are the patrol robots designed for?
        <span class="text-igt-cyan transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="text-slate-300 mt-4">The robots are designed for warehouses, office campuses, parking structures, industrial facilities, and any environment that needs continuous mobile surveillance. They operate in both indoor and outdoor settings.</p>
    </details>
    </div>
  </Section>
  <!-- CTA -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-slate-950 to-black">
    <div class="container mx-auto px-4 md:px-6 max-w-7xl">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
Ready to Deploy Autonomous Security?
</h2>
        <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
See the robots in action. Schedule a live demonstration at your facility or watch our capability videos.
</p>
        <ButtonPrimary href="/booking" text="Book a Security Assessment" />
      </div>
    </div>
  </section>

</BaseLayout>
