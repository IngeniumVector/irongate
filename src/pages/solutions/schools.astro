---
import VerticalPage from '../../layouts/VerticalPage.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
---

<!-- Industry Statistics Sources:
  - NCES: "Indicators of School Crime and Safety: 2022" reports 93% of schools use controlled access
  - Everytown for Gun Safety: 2023 report documents 300+ school shooting incidents since 2013
  - Campus Safety Magazine: Average emergency response time 5-8 minutes for school incidents
  - NCES: 80% of public schools reported at least one violent incident (2019-2020)
  - FBI Active Shooter Reports: Average active shooter incident lasts 12.5 minutes
  - National Center for Education Statistics: 130,930 K-12 schools in the United States
-->

<VerticalPage
  title="School Security Solutions"
  metaDescription="AI-powered school security systems with sub-5-second threat detection. Solar-powered surveillance and access control for K-12 campuses. American-made by Iron Gate Technologies."
  heroHeadline="Protecting Students, Staff, and Communities"
  heroSubheadline="School Security"
  heroDescription="AI-powered threat detection that identifies weapons in under 3 seconds. Solar-powered surveillance and access control systems designed for K-12 campuses, with no infrastructure changes required."
  painPoints={[
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18v-6a5 5 0 1 1 10 0v6"/><path d="M5 21h14"/><path d="M12 3v1M3 12h1M20 12h1M5.6 5.6l.7.7M18.4 5.6l-.7.7"/></svg>',
      title: "Active Threat Response Time",
      description: "The average active shooter incident lasts 12.5 minutes, but law enforcement response averages 5 to 8 minutes. Those first minutes are critical, and most schools lack real-time detection that can trigger immediate lockdown protocols."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 6 3 6 3s6-1 6-3v-5"/></svg>',
      title: "Campus Perimeter Gaps",
      description: "With 80% of public schools reporting at least one violent incident between 2019 and 2020, perimeter security is no longer optional. Large campuses with multiple buildings, parking lots, and athletic fields create blind spots that fixed cameras cannot cover."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"/><path d="M2 20h20"/><path d="M14 12v.01"/></svg>',
      title: "Visitor and Access Management",
      description: "While 93% of schools report using controlled access during school hours, many still rely on manual buzzer systems and paper sign-in logs. These approaches cannot verify identity, track visitor movement, or prevent tailgating."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
      title: "Budget Constraints",
      description: "School districts face tight budgets and competing priorities. Enterprise security systems with recurring subscription fees can cost tens of thousands per year, per building. Schools need professional-grade protection at sustainable price points."
    }
  ]}
  solutions={[
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>',
      title: "AI Threat Detection",
      description: "Computer vision identifies firearms in under 3 seconds and triggers instant alerts to administrators, security personnel, and law enforcement simultaneously. No human monitoring delay."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>',
      title: "Solar-Powered SecMods",
      description: "Deploy portable surveillance units across campus without running power or network cables. Cover parking lots, athletic fields, portable classrooms, and perimeter areas that fixed systems cannot reach."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9" y="10" width="6" height="5" rx="1"/><path d="M10 10V8a2 2 0 1 1 4 0v2"/></svg>',
      title: "Integrated Access Control",
      description: "Card, fob, or mobile credential entry at every door. Centralized management lets administrators lock down an entire campus instantly. Detailed entry logs for every access point."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>',
      title: "Real-Time Alert System",
      description: "Instant notifications to designated staff when threats are detected. Integration with existing communication systems ensures the right people know immediately."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>',
      title: "On-Premise Data Storage",
      description: "Keep sensitive student and campus surveillance data on your own servers. No third-party cloud access to footage of minors. Supports FERPA compliance requirements for student data protection."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
      title: "Custom Configuration",
      description: "Every campus is different. We engineer solutions to match your specific layout, threat profile, and operational needs rather than forcing a one-size-fits-all platform."
    }
  ]}
  stats={[
    { value: "<5s", label: "Threat Detection Speed" },
    { value: "93%", label: "Schools Use Controlled Access" },
    { value: "24/7", label: "Autonomous Monitoring" },
    { value: "0", label: "Subscription Fees Required" }
  ]}
  differentiators={[
    {
      title: "Sub-5-Second Gun Detection",
      description: "While traditional systems rely on human operators watching feeds, Iron Gate's AI identifies weapons automatically and alerts your team in seconds, not minutes."
    },
    {
      title: "No Infrastructure Changes Required",
      description: "Solar power and cellular connectivity mean you can add surveillance to any part of campus without construction, trenching, or network expansion. Deploy during summer break with zero disruption."
    },
    {
      title: "FERPA-Compatible Data Handling",
      description: "On-premise data storage keeps surveillance footage of students on your own servers. No third-party cloud provider has access to sensitive campus recordings."
    },
    {
      title: "Up to 25% Less Than Enterprise Vendors",
      description: "Professional-grade security without the enterprise price tag. No per-camera subscription fees, no long-term contracts. Predictable costs that work within school district budgets."
    }
  ]}
  productLinks={[
    {
      name: "SecMods",
      description: "Portable AI-powered surveillance for parking lots, athletic fields, perimeters, and portable classroom areas.",
      href: "/solutions/secmods/"
    },
    {
      name: "Access Control",
      description: "Card, fob, and mobile credential entry management with centralized campus-wide lockdown capability.",
      href: "/solutions/access-control/"
    },
    {
      name: "RaptorNet",
      description: "Extend secure connectivity across large campuses to support cameras, access points, and alert systems.",
      href: "/solutions/network-infrastructure/"
    }
  ]}
  warrantyTiers={[
    { years: "7 Years", label: "Camera Systems" },
    { years: "5 Years", label: "SecMod Units" },
    { years: "3 Years", label: "All Other Systems" }
  ]}
  ctaHeadline="Let's Discuss Campus Security"
  ctaDescription="Our team will work with your district to design a security solution that protects students and staff while respecting your budget."
>
  <!-- Compliance Callout -->
  <Section>
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title="Built for Education Environments"
        subtitle="Security technology that respects the learning environment"
      />
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">Discreet Monitoring</h3>
          <p class="text-slate-400 text-sm">Security should protect without intimidating. Our systems are designed to be effective without creating a fortress atmosphere that disrupts learning. SecMods blend into campus environments while providing comprehensive coverage.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">District-Wide Scalability</h3>
          <p class="text-slate-400 text-sm">Start with one campus and expand across the district. Centralized management lets security directors monitor multiple schools from a single dashboard. Portable units can move between campuses based on seasonal needs.</p>
        </div>
      </div>
    </div>
  </Section>
</VerticalPage>
