---
import VerticalPage from '../../layouts/VerticalPage.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
---

<!-- Industry Statistics Sources:
  - BoatUS Marine Insurance: Reports $2.5 million+ in theft claims annually from marinas
  - FBI UCR: Boat theft consistently ranks among top property crimes in coastal states
  - National Marine Manufacturers Association (NMMA): 12 million registered recreational boats in the US
  - US Coast Guard: 2022 Recreational Boating Statistics report documents 4,040 accidents
  - Insurance Information Institute: Average boat theft claim exceeds $20,000
  - BoatUS Foundation: Most marina thefts occur between midnight and 5 AM
  - National Insurance Crime Bureau (NICB): Florida consistently leads nation in boat thefts
-->

<VerticalPage
  title="Marine and Marina Security"
  metaDescription="Purpose-built marine security systems for marinas, yacht clubs, and harbors. Weather-resistant surveillance with cellular connectivity. YachtGuard and SecMods by Iron Gate Technologies."
  heroHeadline="Security Built for the Water"
  heroSubheadline="Marine Security"
  heroDescription="Purpose-built surveillance systems designed for marinas, docks, and vessels. Weather-resistant hardware, cellular connectivity, and portable deployment that moves with your fleet."
  painPoints={[
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg>`,
      title: "Harsh Marine Environments",
      description: "Salt spray, humidity, wind, and storm surge destroy standard security equipment within months. Marine environments demand purpose-built hardware that withstands constant exposure to corrosive conditions."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2M15 8V2"/><path d="M18 8v5a6 6 0 0 1-12 0V8Z"/></svg>`,
      title: "Remote Locations Without Power or Internet",
      description: "Many docks, boat ramps, and marina perimeters lack electrical infrastructure and reliable internet. Running power and data lines to waterfront locations is expensive and often impractical."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 18H2a4 4 0 0 0 4-4V6l8 4 8-4v8a4 4 0 0 1-4 4Z"/><path d="M2 22h20"/></svg>`,
      title: "Dock Theft and Vessel Vandalism",
      description: "Florida consistently leads the nation in boat theft according to the National Insurance Crime Bureau, with most marina thefts occurring between midnight and 5 AM. Average boat theft claims exceed $20,000, and that does not account for personal property aboard."
    },
    {
      icon: `<svg class="w-6 h-6 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
      title: "Seasonal and Transient Coverage Needs",
      description: "Marina occupancy fluctuates with seasons. Security needs shift as vessels arrive and depart. Fixed camera installations cannot adapt to changing dock layouts, temporary moorings, or seasonal slips."
    }
  ]}
  solutions={[
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><line x1="12" y1="8" x2="12" y2="22"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/></svg>`,
      title: "YachtGuard Vessel Security",
      description: "Purpose-built for boats and yachts with suction-cup and rail-mount options. Portable, weather-resistant, and self-powered. Monitor your vessel 24/7 whether docked or at anchor."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>`,
      title: "SecMods for Dock and Perimeter",
      description: "Solar-powered surveillance units that cover docks, boat ramps, parking areas, and fuel stations. Deploy without running power or network cables to the waterfront."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>`,
      title: "Cellular Connectivity",
      description: "4G/5G LTE means no marina WiFi required. Reliable connections even at remote anchorages, outlying docks, and locations where broadband is unavailable."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>`,
      title: "AI-Powered Detection",
      description: "Automated alerts for unauthorized dock access, unusual activity during overnight hours, and perimeter breaches. The system watches so your harbor master does not have to monitor screens around the clock."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>`,
      title: "Portable Seasonal Deployment",
      description: "Move units between docks as occupancy changes. Redeploy to cover temporary events, regattas, or boat shows. No permanent installation means no wasted coverage on empty slips."
    },
    {
      icon: `<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
      title: "Weather-Resistant Construction",
      description: "All marine-deployed hardware is built to withstand salt spray, humidity, UV exposure, and storm conditions. Industrial-grade enclosures protect electronics in the harshest coastal environments."
    }
  ]}
  stats={[
    { value: "$20K+", label: "Average Boat Theft Claim" },
    { value: "12M", label: "Registered US Recreational Boats" },
    { value: "24/7", label: "Autonomous Monitoring" },
    { value: "0", label: "External Power Required" }
  ]}
  differentiators={[
    {
      title: "Purpose-Built for Marine Environments",
      description: "YachtGuard is not a repurposed land camera. It was designed from the ground up for boats, with suction-cup and rail mounting, weather-resistant housings, and portable power systems that handle marine conditions."
    },
    {
      title: "No Infrastructure Investment",
      description: "Solar power and cellular connectivity eliminate the need for electrical runs and network cabling to waterfront locations. Deploy professional-grade security at a fraction of the infrastructure cost."
    },
    {
      title: "On-Premise Data Option",
      description: "Keep your marina's surveillance footage on local servers rather than a third-party cloud. Owners and operators retain full control over who accesses recordings of their vessels and facilities."
    },
    {
      title: "American-Made, Florida-Based",
      description: "Manufactured in Holly Hill, Florida by a team that understands coastal conditions firsthand. Direct access to engineering support, not a call center on the other side of the country."
    }
  ]}
  productLinks={[
    {
      name: "YachtGuard",
      description: "Purpose-built vessel security with suction-cup mounting, weather-resistant construction, and portable power.",
      href: "/solutions/yachtguard/"
    },
    {
      name: "SecMods",
      description: "Portable surveillance for docks, boat ramps, parking areas, and marina perimeters. Solar-powered with cellular connectivity.",
      href: "/solutions/secmods/"
    }
  ]}
  warrantyTiers={[
    { years: "7 Years", label: "Camera Systems" },
    { years: "5 Years", label: "SecMod Units" },
    { years: "3 Years", label: "All Other Systems" }
  ]}
  ctaHeadline="Protect Your Marina or Fleet"
  ctaDescription="Our team will design a marine security solution that covers your docks, vessels, and waterfront property."
>
  <!-- Marina-Specific Section -->
  <Section>
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title="Coverage for Every Waterfront Need"
        subtitle="From individual vessels to full-marina security"
      />
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 text-center">
          <div class="text-4xl mb-4"><svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M12 1v4"/></svg></div>
          <h3 class="text-lg font-semibold text-white mb-3">Individual Vessels</h3>
          <p class="text-slate-400 text-sm">YachtGuard mounts directly to your boat for 24/7 monitoring whether docked, anchored, or in transit. Portable and self-powered.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 text-center">
          <div class="text-4xl mb-4"><svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 18H2a4 4 0 0 0 4-4V6l8 4 8-4v8a4 4 0 0 1-4 4Z"/><path d="M2 22h20"/></svg></div>
          <h3 class="text-lg font-semibold text-white mb-3">Docks and Slips</h3>
          <p class="text-slate-400 text-sm">SecMods provide elevated surveillance across entire dock sections. Cover fuel stations, boat ramps, and access points without permanent installation.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 text-center">
          <div class="text-4xl mb-4"><svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><rect x="9" y="12" width="6" height="8"/><path d="M3 20h2M19 20h2"/></svg></div>
          <h3 class="text-lg font-semibold text-white mb-3">Full Marina Perimeter</h3>
          <p class="text-slate-400 text-sm">Combine multiple SecMod units with access control at gates and entry points for comprehensive marina-wide coverage. Scale up or down with seasonal demand.</p>
        </div>
      </div>
    </div>
  </Section>
</VerticalPage>
