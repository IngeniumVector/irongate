---
import VerticalPage from '../../layouts/VerticalPage.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
---

<!-- Industry Statistics Sources:
  - FBI UCR / CargoNet: Cargo theft costs US businesses an estimated $15-35 billion annually
  - CargoNet: Average cargo theft claim value exceeds $200,000; 2023 recorded 1,778 theft events
  - FreightWaves / CargoNet: Strategic theft (fraud-based) increased 430% from 2022 to 2023
  - Bureau of Labor Statistics (BLS): Warehousing and storage sector employs 1.9M+ workers
  - Supply Chain Dive: 70% of cargo thefts occur at unsecured parking lots and rest areas
  - National Retail Federation: Organized retail crime costs retailers $100B+ annually, much tied to supply chain
  - Department of Transportation: Loading dock theft peaks between 6PM Friday and 6AM Monday
-->

<VerticalPage
  title="Logistics and Warehouse Security"
  metaDescription="AI-powered security for warehouses, distribution centers, and freight yards. Portable surveillance with license plate recognition, cargo monitoring, and autonomous threat detection by Iron Gate Technologies."
  heroHeadline="Securing the Supply Chain, End to End"
  heroSubheadline="Logistics Security"
  heroDescription="Portable, AI-powered surveillance for warehouses, freight yards, and distribution centers. Solar-powered systems that deploy without infrastructure investment and protect high-value cargo around the clock."
  painPoints={[
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5M12 22V12"/></svg>',
      title: "Cargo Theft at Scale",
      description: "Cargo theft costs U.S. businesses an estimated $15 to $35 billion annually. CargoNet recorded 1,778 theft events in 2023, with the average claim value exceeding $200,000. Strategic theft involving fraud and identity deception increased 430% from 2022 to 2023."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1M12 18h1M7 18h1"/></svg>',
      title: "Warehouse Perimeter Exposure",
      description: "Large warehouse facilities with multiple loading docks, staging areas, and employee entrances create extensive perimeters that are difficult to monitor with fixed cameras alone. Blind spots at fence lines and remote corners invite unauthorized access."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h1"/><path d="M15 18h2l3-3V8h-5"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>',
      title: "Loading Dock Vulnerability",
      description: "Department of Transportation data shows that loading dock theft peaks between 6 PM Friday and 6 AM Monday, when staffing is lowest. High-value goods sitting on docks during shift changes and weekends are primary targets."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>',
      title: "Supply Chain Visibility Gaps",
      description: "Approximately 70% of cargo thefts occur at unsecured parking lots and rest areas according to CargoNet research. Once goods leave the warehouse, visibility drops. Comprehensive security requires coverage that extends beyond the building walls."
    }
  ]}
  solutions={[
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h1"/><path d="M15 18h2l3-3V8h-5"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>',
      title: "FreightGuard Cargo Monitoring",
      description: "Purpose-built for logistics environments with license plate recognition, vehicle tracking, and automated alerts for unauthorized trailer movement. Monitor loading docks, staging areas, and yard operations 24/7."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>',
      title: "SecMods for Perimeter and Yard",
      description: "Solar-powered surveillance units that cover fence lines, parking areas, and remote sections of large properties. Deploy without running power or network cables across expansive warehouse campuses."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9" y="10" width="6" height="5" rx="1"/><path d="M10 10V8a2 2 0 1 1 4 0v2"/></svg>',
      title: "Access Control Integration",
      description: "Control entry to warehouses, loading docks, and restricted areas with card, fob, or biometric credentials. Track every entry and exit with time-stamped logs for loss prevention investigations."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>',
      title: "AI-Powered Threat Detection",
      description: "Automated monitoring identifies unauthorized vehicles, after-hours activity, fence-line breaches, and suspicious behavior patterns. Instant alerts to security teams without requiring constant human monitoring."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>',
      title: "Cellular Connectivity",
      description: "4G/5G LTE connections mean no dependency on warehouse WiFi networks. Independent connectivity ensures surveillance stays operational even during network outages or IT maintenance windows."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>',
      title: "Portable Deployment",
      description: "Relocate units as operations shift between facilities, seasonal storage sites, or temporary staging areas. No permanent installation means security moves with your supply chain."
    }
  ]}
  stats={[
    { value: "$35B", label: "Annual US Cargo Theft Cost" },
    { value: "1,778", label: "Theft Events Tracked in 2023" },
    { value: "430%", label: "Strategic Theft Increase" },
    { value: "24/7", label: "Autonomous Monitoring" }
  ]}
  differentiators={[
    {
      title: "FreightGuard: Purpose-Built for Logistics",
      description: "Not a generic camera repurposed for a warehouse. FreightGuard is engineered specifically for freight and logistics environments with license plate recognition, vehicle tracking, and loading dock monitoring."
    },
    {
      title: "No Infrastructure Investment",
      description: "Solar power and cellular connectivity eliminate costly electrical and network runs across large properties. Deploy professional-grade surveillance at a fraction of the infrastructure cost of permanent installations."
    },
    {
      title: "On-Premise Data for Loss Prevention",
      description: "Keep surveillance footage on your own servers for internal investigations and insurance claims. No third-party cloud provider controls access to your evidence. Chain of custody stays with your security team."
    },
    {
      title: "Scales with Your Operation",
      description: "Add units during peak seasons, relocate to temporary facilities, or expand coverage as your operation grows. Portable deployment means your security investment adapts to operational changes."
    }
  ]}
  productLinks={[
    {
      name: "FreightGuard",
      description: "License plate recognition, vehicle tracking, and intelligent monitoring built for freight yards, loading docks, and distribution centers.",
      href: "/solutions/freightguard/"
    },
    {
      name: "SecMods",
      description: "Portable AI-powered surveillance for warehouse perimeters, parking areas, and remote sections of large properties.",
      href: "/solutions/secmods/"
    },
    {
      name: "Access Control",
      description: "Card, fob, and biometric entry management for warehouses, loading docks, and restricted storage areas.",
      href: "/solutions/access-control/"
    }
  ]}
  warrantyTiers={[
    { years: "7 Years", label: "Camera Systems" },
    { years: "5 Years", label: "SecMod Units" },
    { years: "3 Years", label: "All Other Systems" }
  ]}
  ctaHeadline="Protect Your Supply Chain"
  ctaDescription="Our team will design a security solution that covers your warehouses, freight yards, and distribution operations."
>
  <!-- Logistics-Specific Section -->
  <Section>
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title="Coverage Across the Supply Chain"
        subtitle="From warehouse floor to final mile"
      />
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 text-center">
          <div class="text-4xl mb-4"><svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1M12 18h1M7 18h1"/></svg></div>
          <h3 class="text-lg font-semibold text-white mb-3">Warehouse Perimeter</h3>
          <p class="text-slate-400 text-sm">SecMods provide elevated surveillance along fence lines, parking areas, and remote property corners. Cover the areas that fixed cameras cannot reach.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 text-center">
          <div class="text-4xl mb-4"><svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h1"/><path d="M15 18h2l3-3V8h-5"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg></div>
          <h3 class="text-lg font-semibold text-white mb-3">Loading Docks and Yards</h3>
          <p class="text-slate-400 text-sm">FreightGuard monitors trailer movement, tracks vehicles entering and exiting, and alerts on unauthorized activity during off-hours when theft risk is highest.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 text-center">
          <div class="text-4xl mb-4"><svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9" y="10" width="6" height="5" rx="1"/><path d="M10 10V8a2 2 0 1 1 4 0v2"/></svg></div>
          <h3 class="text-lg font-semibold text-white mb-3">Facility Access Points</h3>
          <p class="text-slate-400 text-sm">Access control at every entry point tracks employee and visitor movement with time-stamped logs. Instant lockdown capability during security incidents.</p>
        </div>
      </div>
    </div>
  </Section>
</VerticalPage>
