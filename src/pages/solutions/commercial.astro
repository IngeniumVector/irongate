---
import VerticalPage from '../../layouts/VerticalPage.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
---

<!-- Industry Statistics Sources:
  - BOMA International (Building Owners and Managers Association): Security is consistently a top-3 operational expense for commercial properties
  - IREM (Institute of Real Estate Management): Tenant satisfaction surveys rank safety/security as #1 or #2 priority
  - Bureau of Justice Statistics: Commercial properties experience approximately 1.1 million burglaries annually
  - National Crime Prevention Council: Adequate lighting and surveillance reduce parking garage crime by up to 50%
  - CBRE Research: Office vacancy rates averaged 18.6% nationally in 2023, increasing after-hours security needs
  - Kastle Systems Back to Work Barometer: Hybrid work patterns create unpredictable building occupancy
  - ASIS International: Average cost of a commercial property security incident exceeds $10,000 including liability
-->

<VerticalPage
  title="Commercial Property Security"
  metaDescription="AI-powered security for commercial buildings, office complexes, and multi-tenant properties. Access control, parking garage surveillance, and portable monitoring by Iron Gate Technologies."
  heroHeadline="Securing Commercial Properties and Their Tenants"
  heroSubheadline="Commercial Security"
  heroDescription="Integrated surveillance and access control for office buildings, multi-tenant properties, and commercial campuses. Scalable systems that protect tenants, manage visitor access, and cover parking structures without enterprise subscription costs."
  painPoints={[
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M12 6h.01M8 10h.01M16 10h.01M12 10h.01M8 14h.01M16 14h.01M12 14h.01"/></svg>',
      title: "Multi-Tenant Access Complexity",
      description: "Commercial properties with multiple tenants need access systems that serve different organizations with different schedules, clearance levels, and visitor policies. Key-based systems cannot scale, and basic badge readers lack the flexibility to manage dynamic tenant rosters."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>',
      title: "Parking Garage Vulnerability",
      description: "The National Crime Prevention Council reports that adequate surveillance reduces parking garage crime by up to 50%. Multi-level structures with stairwells, blind corners, and limited lighting are high-risk areas for tenants and visitors, especially during early morning and evening hours."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>',
      title: "After-Hours and Vacancy Risks",
      description: "National office vacancy rates averaged 18.6% in 2023 according to CBRE research, and hybrid work patterns make building occupancy unpredictable. Empty floors and unused spaces increase vulnerability to unauthorized access, vandalism, and liability incidents."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
      title: "Security as Operating Expense",
      description: "BOMA International consistently ranks security among the top three operational expenses for commercial properties. Property managers need professional-grade protection that fits within operating budgets without per-camera subscription fees that compound across large portfolios."
    }
  ]}
  solutions={[
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9" y="10" width="6" height="5" rx="1"/><path d="M10 10V8a2 2 0 1 1 4 0v2"/></svg>',
      title: "Scalable Access Control",
      description: "Tenant-specific access zones with card, fob, or mobile credentials. Manage multiple organizations in one building with independent schedules, visitor permissions, and clearance levels. Add or remove tenant access instantly."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>',
      title: "SecMods for Parking and Perimeter",
      description: "Solar-powered surveillance units that cover parking garages, loading areas, and exterior perimeters. Deploy to any floor or area without running additional power or network cabling through the building."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>',
      title: "AI-Powered Monitoring",
      description: "Automated detection of unauthorized access attempts, after-hours activity on vacant floors, and suspicious behavior in common areas. Real-time alerts to property management and security teams without staffing a 24/7 monitoring desk."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>',
      title: "RaptorNet",
      description: "Extend secure connectivity to parking structures, rooftops, and exterior areas that existing building networks do not reach. Independent security networks that operate separately from tenant IT infrastructure."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>',
      title: "On-Premise Data Storage",
      description: "Keep surveillance footage on property-controlled servers. No third-party cloud provider has access to recordings of tenants, visitors, or building operations. Property managers retain full control over security data."
    },
    {
      icon: '<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>',
      title: "Centralized Portfolio Management",
      description: "For property management firms with multiple buildings, centralized dashboards provide a unified security view across the portfolio. Monitor access events, camera feeds, and alerts from a single interface."
    }
  ]}
  stats={[
    { value: "50%", label: "Crime Reduction with Surveillance" },
    { value: "18.6%", label: "National Office Vacancy Rate" },
    { value: "24/7", label: "Autonomous Monitoring" },
    { value: "0", label: "Per-Camera Subscription Fees" }
  ]}
  differentiators={[
    {
      title: "No Subscription Lock-In",
      description: "Enterprise competitors charge per-camera subscription fees that compound across large properties and portfolios. Iron Gate provides professional-grade security at up to 25% less, with no recurring cloud fees or long-term contract requirements."
    },
    {
      title: "Tenant-Ready Access Management",
      description: "Multi-tenant access control that scales with your building. Independent zones, schedules, and visitor policies per tenant. Add new tenants in minutes. Deactivate departing tenants instantly. No reconfiguration of the entire system."
    },
    {
      title: "On-Premise Data Control",
      description: "Property managers retain full ownership of surveillance data. No third-party cloud access to recordings of tenant activities, building operations, or security incidents. Simplifies liability management and tenant privacy compliance."
    },
    {
      title: "American-Made with Direct Support",
      description: "Manufactured in Holly Hill, Florida with direct access to our engineering team. Commercial properties need responsive support when systems need attention, not a ticket queue at an enterprise call center."
    }
  ]}
  productLinks={[
    {
      name: "SecMods",
      description: "Portable surveillance for parking garages, loading docks, exterior perimeters, and construction zones during renovations.",
      href: "/solutions/secmods/"
    },
    {
      name: "Access Control",
      description: "Multi-tenant entry management with independent zones, mobile credentials, visitor management, and instant lockdown capability.",
      href: "/solutions/access-control/"
    },
    {
      name: "RaptorNet",
      description: "Extend secure connectivity to parking structures, rooftops, and exterior areas beyond existing building networks.",
      href: "/solutions/network-infrastructure/"
    }
  ]}
  warrantyTiers={[
    { years: "7 Years", label: "Camera Systems" },
    { years: "5 Years", label: "SecMod Units" },
    { years: "3 Years", label: "All Other Systems" }
  ]}
  ctaHeadline="Secure Your Commercial Property"
  ctaDescription="Our team will design a security solution that protects your tenants, manages access, and fits your operating budget."
>
  <!-- Commercial-Specific Section -->
  <Section>
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title="Security for Every Property Type"
        subtitle="From single buildings to multi-site portfolios"
      />
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">Office Buildings and Complexes</h3>
          <p class="text-slate-400 text-sm">Multi-tenant access control, lobby monitoring, parking garage coverage, and after-hours protection. Integrated systems that serve building management and individual tenant security needs from a single platform.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">Property Management Portfolios</h3>
          <p class="text-slate-400 text-sm">Centralized management across multiple properties with consistent access control policies, unified reporting, and portable units that can redeploy between buildings based on occupancy and seasonal needs.</p>
        </div>
      </div>
    </div>
  </Section>
</VerticalPage>
