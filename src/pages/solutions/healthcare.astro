---
import VerticalPage from '../../layouts/VerticalPage.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
---

<!-- Industry Statistics Sources:
  - Bureau of Labor Statistics (BLS): Healthcare workers suffer workplace violence at 5x the rate of other industries
  - OSHA: 73% of all nonfatal workplace violence injuries occur in healthcare settings
  - American Hospital Association (AHA): 44% of nurses reported experiencing physical violence in 2022
  - Joint Commission Sentinel Event Alert #59: Workplace violence in healthcare is a persistent safety issue
  - IAHSS (International Association for Healthcare Security and Safety): Hospital security incidents increased 47% from 2012-2022
  - CMS (Centers for Medicare & Medicaid): Hospitals must meet Conditions of Participation including security
  - HHS: HIPAA Security Rule requires physical safeguards for electronic protected health information
-->

<VerticalPage
  title="Healthcare Facility Security"
  metaDescription="AI-powered security for hospitals, clinics, and healthcare facilities. HIPAA-compatible surveillance with on-premise data, access control, and autonomous patrol systems by Iron Gate Technologies."
  heroHeadline="Protecting Patients, Staff, and Critical Infrastructure"
  heroSubheadline="Healthcare Security"
  heroDescription="AI-powered surveillance and access control designed for the unique challenges of healthcare environments. On-premise data storage supports HIPAA physical safeguard requirements while autonomous systems provide 24/7 protection."
  painPoints={[
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18v-6a5 5 0 1 1 10 0v6"/><path d="M5 21h14"/><path d="M12 3v1M3 12h1M20 12h1M5.6 5.6l.7.7M18.4 5.6l-.7.7"/></svg>",
      title: "Emergency Department Violence",
      description: "Healthcare workers experience workplace violence at five times the rate of workers in other industries according to the Bureau of Labor Statistics. The American Hospital Association reports 44% of nurses experienced physical violence in 2022. Emergency departments are particularly vulnerable due to high-stress situations and open access."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"/><path d="M2 20h20"/><path d="M14 12v.01"/></svg>",
      title: "Restricted Area Access Control",
      description: "Pharmacies, surgical suites, neonatal units, and behavioral health wards all require different levels of access restriction. Many facilities still rely on physical keys or basic badge systems that cannot adapt to dynamic staffing patterns or emergency lockdown scenarios."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>",
      title: "Parking Structure and Campus Safety",
      description: "Large hospital campuses with multi-level parking garages, remote employee lots, and pedestrian walkways create zones where staff and visitors feel vulnerable, particularly during shift changes at early morning and late night hours."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>",
      title: "Regulatory Compliance Requirements",
      description: "HIPAA requires physical safeguards for areas where electronic protected health information is stored or accessed. CMS Conditions of Participation include security requirements. Healthcare facilities need security infrastructure that supports compliance documentation."
    }
  ]}
  solutions={[
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>",
      title: "AI Threat Detection",
      description: "Automated weapon identification in under 5 seconds triggers instant alerts to security teams, administrators, and law enforcement. Early detection in lobbies, waiting areas, and entry points provides critical response time."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9" y="10" width="6" height="5" rx="1"/><path d="M10 10V8a2 2 0 1 1 4 0v2"/></svg>",
      title: "Tiered Access Control",
      description: "Zone-based access management with card, fob, or biometric credentials. Different clearance levels for pharmacies, surgical suites, behavioral health units, and administrative areas. Emergency lockdown across any zone or the entire facility."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2M20 14h2M15 13v2M9 13v2"/></svg>",
      title: "Autonomous Patrol Robots",
      description: "Self-navigating patrol units that provide continuous mobile surveillance across large campuses, parking structures, and perimeter areas. Stair-climbing capability covers multi-level facilities without human escort."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>",
      title: "SecMods for Campus Coverage",
      description: "Solar-powered surveillance units for parking garages, construction zones during facility expansion, and remote campus areas. Deploy without impacting existing hospital IT infrastructure."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>",
      title: "On-Premise Data Storage",
      description: "Keep all surveillance footage on your own servers. No third-party cloud provider has access to recordings of patients, staff, or protected areas. Supports HIPAA physical safeguard documentation requirements."
    },
    {
      icon: "<svg class="w-8 h-8 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>",
      title: "Independent Connectivity",
      description: "Cellular-connected systems operate independently from hospital networks. Security surveillance stays operational during IT maintenance, network incidents, or cyber events affecting the main infrastructure."
    }
  ]}
  stats={[
    { value: "5x", label: "Violence Rate vs Other Industries" },
    { value: "73%", label: "Workplace Violence in Healthcare" },
    { value: "44%", label: "Nurses Reporting Physical Violence" },
    { value: "24/7", label: "Autonomous Monitoring" }
  ]}
  differentiators={[
    {
      title: "HIPAA-Compatible Architecture",
      description: "On-premise data storage keeps surveillance recordings under your facility's direct control. No third-party cloud access to footage of patients, protected health areas, or sensitive operations. Supports physical safeguard documentation for compliance audits."
    },
    {
      title: "Network-Independent Operation",
      description: "Solar power and cellular connectivity mean security systems do not depend on hospital IT infrastructure. Surveillance stays operational during network outages, cyber incidents, or planned maintenance windows."
    },
    {
      title: "Full Product Suite for Complex Campuses",
      description: "From SecMods covering parking garages to autonomous robots patrolling corridors to tiered access control at every restricted area, Iron Gate covers the full spectrum of healthcare security needs with integrated solutions."
    },
    {
      title: "American-Made with Direct Engineering Support",
      description: "Manufactured in Holly Hill, Florida with direct access to our engineering team. Healthcare facilities need responsive support, not an enterprise call center. We design custom configurations for your specific campus layout."
    }
  ]}
  productLinks={[
    {
      name: "SecMods",
      description: "Portable AI-powered surveillance for parking structures, campus perimeters, and construction zones during facility expansion.",
      href: "/solutions/secmods/"
    },
    {
      name: "Access Control",
      description: "Zone-based entry management with tiered clearance levels, emergency lockdown, and detailed audit trails for compliance.",
      href: "/solutions/access-control/"
    },
    {
      name: "Autonomous Patrol Robots",
      description: "Self-navigating mobile surveillance units with stair-climbing capability for multi-level facilities and large campus coverage.",
      href: "/solutions/autonomous-robots/"
    },
    {
      name: "RaptorNet",
      description: "Industrial-grade connectivity solutions that extend coverage to remote campus areas without impacting hospital networks.",
      href: "/solutions/network-infrastructure/"
    }
  ]}
  warrantyTiers={[
    { years: "7 Years", label: "Camera Systems" },
    { years: "5 Years", label: "SecMod Units" },
    { years: "3 Years", label: "All Other Systems" }
  ]}
  ctaHeadline="Secure Your Healthcare Facility"
  ctaDescription="Our team will design a security solution that protects patients and staff while supporting your compliance requirements."
>
  <!-- Healthcare-Specific Section -->
  <Section>
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title="Security Across the Healthcare Campus"
        subtitle="Integrated protection for every area of your facility"
      />
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">Emergency Department Protection</h3>
          <p class="text-slate-400 text-sm">AI threat detection at ED entrances identifies weapons before they enter the department. Access control separates waiting areas from treatment zones. Instant alerts to security teams allow rapid response before situations escalate.</p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">Multi-Facility Management</h3>
          <p class="text-slate-400 text-sm">For health systems with multiple hospitals, outpatient clinics, and satellite facilities, centralized management provides a unified security view. Portable SecMod units can redeploy between facilities based on current needs and construction schedules.</p>
        </div>
      </div>
    </div>
  </Section>
</VerticalPage>
