---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/layout/Hero.astro';
import Section from '../components/layout/Section.astro';
import ButtonPrimary from '../components/buttons/ButtonPrimary.astro';
---

<BaseLayout 
  title="Contact" 
  description="Contact Iron Gate Technologies: American-made security solutions. Call 904-896-5618 or email ats@irongate.world."
>
  <Hero 
    variant="centered"
    title="Get in Touch"
    description="Ready to discuss your security needs? Our team is standing by to help."
  />

  <Section>
    <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Contact Information -->
      <div>
        <h2 class="text-2xl font-bold text-white mb-8">Contact Information</h2>
        
        <div class="space-y-6">
          <!-- Phone -->
          <div class="flex items-start">
            <div class="text-igt-cyan text-2xl mr-4" aria-hidden="true"><svg class="w-6 h-6 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">Phone</h3>
              <a href="tel:+19048965618" class="text-slate-300 hover:text-igt-cyan transition-colors text-lg">
                904-896-5618
              </a>

            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start">
            <div class="text-igt-cyan text-2xl mr-4" aria-hidden="true"><svg class="w-6 h-6 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">Email</h3>
              <a href="mailto:ats@irongate.world" class="text-slate-300 hover:text-igt-cyan transition-colors">
                ats@irongate.world
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start">
            <div class="text-igt-cyan text-2xl mr-4" aria-hidden="true"><svg class="w-6 h-6 text-igt-cyan" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">Address</h3>
              <p class="text-slate-300">
                232 Carswell Ave<br />
                Holly Hill, FL 32117<br />
                United States
              </p>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="mt-8">
          <ButtonPrimary href="/booking" text="Book a Security Assessment" class="w-full" />
        </div>
      </div>

      <!-- Office Hours & Info -->
      <div>
        <h2 class="text-2xl font-bold text-white mb-8">Office Hours</h2>
        
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 mb-6">
          <div class="space-y-3 text-slate-300">
            <div class="flex justify-between">
              <span>Monday - Friday:</span>
              <span class="text-white font-medium">8:00 AM - 6:00 PM EST</span>
            </div>
            <div class="flex justify-between">
              <span>Saturday:</span>
              <span class="text-white font-medium">9:00 AM - 3:00 PM EST</span>
            </div>
            <div class="flex justify-between">
              <span>Sunday:</span>
              <span class="text-white font-medium">Closed</span>
            </div>
          </div>
        </div>

        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-white mb-3">Response Time</h3>
          <p class="text-slate-300 mb-4">
            We typically respond to inquiries within 2-4 business hours during office hours. For urgent security matters, please call our main line directly.
          </p>
          <p class="text-slate-400 text-sm">
            Emergency support available 24/7 for existing clients with active monitoring agreements.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Quick Links -->
  <Section class="bg-slate-950">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-6">Ready to Get Started?</h2>
      <p class="text-slate-300 text-lg mb-8">
        Schedule a consultation to discuss your security needs, or explore our solutions to learn more about what we offer.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <ButtonPrimary href="/booking" text="Book a Security Assessment" />
        <a href="/solutions" class="inline-flex items-center justify-center px-8 py-3 border-2 border-igt-cyan text-igt-cyan font-semibold rounded-lg hover:bg-igt-cyan hover:text-black transition-all duration-200">
          View Solutions
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
